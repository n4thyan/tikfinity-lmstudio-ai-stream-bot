# Copy this file to .env and edit the values.

# Chat source platform.
# Options: tiktok, youtube, kick-webhook
CHAT_PLATFORM=tiktok

# TikTok via Tikfinity local WebSocket endpoint.
# The exact URL can be checked in Tikfinity's TikTok LIVE API page.
TIKFINITY_WS_URL=ws://127.0.0.1:21213/

# YouTube Live chat.
# Use either YOUTUBE_LIVE_CHAT_ID directly, or set YOUTUBE_VIDEO_ID and let the bridge discover the active chat ID.
YOUTUBE_API_KEY=
YOUTUBE_LIVE_CHAT_ID=
YOUTUBE_VIDEO_ID=
YOUTUBE_POLL_FLOOR_SECONDS=2

# Kick chat webhook receiver.
# For local testing this listens on your PC. For a real Kick app webhook, expose it with a tunnel/reverse proxy.
KICK_WEBHOOK_HOST=127.0.0.1
KICK_WEBHOOK_PORT=8790
KICK_WEBHOOK_PATH=/kick/webhook

# LM Studio local server. Start this from LM Studio's Developer tab.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TIMEOUT_SECONDS=45
LMSTUDIO_TEMPERATURE=0.8
LMSTUDIO_MAX_TOKENS=120

# Discord webhook. Leave blank to disable Discord logging.
DISCORD_WEBHOOK_URL=
DISCORD_LOG_ACCEPTED=true
DISCORD_LOG_BLOCKED=true
DISCORD_LOG_REPLIES=true

# OBS overlay server.
OVERLAY_HOST=127.0.0.1
OVERLAY_PORT=8787
OVERLAY_TTS_ENABLED=false

# Chat command and queue behaviour.
COMMAND_PREFIX=!
USER_COOLDOWN_SECONDS=20
GLOBAL_COOLDOWN_SECONDS=2
QUEUE_LIMIT=10
MAX_PROMPT_CHARS=180
MAX_REPLY_CHARS=260

# Personality / safety config.
PERSONALITY_FILE=config/bot_personality.example.txt
SAFETY_CONFIG_FILE=config/safety_words.example.json

# Local kill switch. Create this file to pause chat replies, delete it to resume.
PAUSE_FILE=config/PAUSE_STREAM.txt

# Debugging.
LOG_LEVEL=INFO
